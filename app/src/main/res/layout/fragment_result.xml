<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="32dp"
    android:paddingTop="12dp"
    android:background="@drawable/bg_bottom_sheet_white">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Erkannte Gegenstände"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:paddingHorizontal="24dp"
        android:layout_marginBottom="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/detectedItemsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        tools:listitem="@layout/item_detected" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="16dp">

        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_search_field"
            android:hint="Gegenstand suchen..."
            android:paddingStart="48dp"
            android:paddingEnd="16dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="12dp"
            android:inputType="text" />
    </FrameLayout>

    <Button
        android:id="@+id/rescanButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="Erneut scannen"
        android:textAllCaps="false"
        android:backgroundTint="#1B5E20"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp"
        android:drawableStart="@drawable/ic_refresh"
        android:drawablePadding="8dp"
        android:paddingStart="24dp" />

</LinearLayout>
