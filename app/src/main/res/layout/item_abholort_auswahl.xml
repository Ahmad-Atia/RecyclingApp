<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="2dp"
    app:strokeColor="@android:color/transparent"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_auswahl_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_light_green"
            android:gravity="center"
            android:text="🏠"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_auswahl_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zuhause"
                android:textColor="#1B5E20"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_auswahl_adresse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Musterstraße 1, 10115 Berlin"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_auswahl_indikator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textColor="#999999"
            android:textSize="20sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
