<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginView">

    <fragment
        android:id="@+id/loginView"
        android:name="com.example.recyclingapp.ui.LoginView"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginView_to_dashboardView"
            app:destination="@id/dashboardView" />
    </fragment>

    <fragment
        android:id="@+id/dashboardView"
        android:name="com.example.recyclingapp.ui.DashboardView"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardView_to_cameraView"
            app:destination="@id/cameraView" />
    </fragment>

    <fragment
        android:id="@+id/cameraView"
        android:name="com.example.recyclingapp.ui.CameraView"
        android:label="Camera"
        tools:layout="@layout/fragment_camera">
        <action
            android:id="@+id/action_cameraView_to_resultView"
            app:destination="@id/resultView" />
    </fragment>

    <fragment
        android:id="@+id/resultView"
        android:name="com.example.recyclingapp.ui.ResultView"
        android:label="Scan Result"
        tools:layout="@layout/fragment_result" />

</navigation>
