<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plastik richtig trennen"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/neutral"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scanne deinen Abfall und finde heraus, in welche Tonne er gehört."
            android:textSize="16sp"
            android:textColor="@color/neutral"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/userEmailTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email: user@example.com"
                    android:textColor="@color/neutral"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/ecoScoreTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eco Score: 100"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/startScanButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="JETZT SCANNEN"
            style="@style/PrimaryButtonStyle"
            app:icon="@drawable/baseline_photo_camera_24"
            app:iconGravity="textStart"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/viewCalendarButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Abfallkalender"
            style="@style/SecondaryButtonStyle" />

    </LinearLayout>
</ScrollView>
